{
  "$schema": "railway.app.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "image": "nixpacks/images/python312"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckPort": 8000
  }
}
